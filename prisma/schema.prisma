generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("PRISMA_DATABASE_URL")
}

model User {
  id                  String         @id @default(cuid())
  firstName           String
  lastName            String
  email               String         @unique
  password            String
  gender              String?
  university          String?
  uniqueCode          String
  role                String         @default("user")
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  hasApproachAccess   Boolean        @default(false)
  hasCoursesAccess    Boolean        @default(false)
  hasQbankAccess      Boolean        @default(false)
  hasWizaryExamAccess Boolean        @default(true)
  isLocked            Boolean        @default(false)
  lastLoginAt         DateTime?
  responses           UserResponse[]
  sessions            UserSession[]

  @@map("users")
}

model UserResponse {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  userAnswer Int
  isCorrect  Boolean
  isFlagged  Boolean  @default(false)
  answeredAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@map("user_responses")
}

model UserSession {
  id         String   @id @default(cuid())
  userId     String
  sessionId  String   @unique
  deviceInfo String?
  ipAddress  String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

model UniqueCode {
  id        String    @id @default(cuid())
  code      String    @unique
  used      Boolean   @default(false)
  usedBy    String?
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("unique_codes")
}

model Exam {
  id         String   @id @default(cuid())
  title      String
  subject    String
  examTime   Int
  order      Int      @default(1)
  secretCode String   @default("HaiderAlaa")
  questions  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("exams")
}

model KeyValue {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("kv_store")
}
